// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SpareType {
  Spare
  Additive
  Accessory
}

enum OrderType {
  Sale
  ReturnToServiceCenter
  WarrantyAMC
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  phoneNumber    String
  franchiseeName String
  gstin          String
  password       String
  createdAt      DateTime @default(now())
}

model Material {
  id            String   @id @default(uuid())
  materialCode  String   @unique
  description   String
  materialGroup String
  createdAt     DateTime @default(now())

  prices        MaterialPrice[]
  invoiceItems  InvoiceItem[]
  engineerStock EngineerStock[]
  saleOrders    SaleOrder[]
  warrantyAmcOrders    WarrantyAmcOrder[]
  returnToGodownOrders ReturnToGodownOrder[]
  customerReturns      CustomerReturn[]
  godownStock          GodownStock[]
}

model MaterialPrice {
  id              String   @id @default(uuid())
  conditionRecord String
  conditionType   String
  rate            Float
  validFrom       DateTime
  validTo         DateTime

  materialId String
  material   Material @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  invoiceDate   DateTime
  customerName  String
  franchiseeId  String

  createdAt DateTime @default(now())

  items       InvoiceItem[]
  godownStock GodownStock[]
}

model InvoiceItem {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  materialCode String
  material     Material @relation(fields: [materialCode], references: [materialCode])

  description String
  hsn         String?
  quantity    Float
  uom         String
  unitPrice   Float
  totalAmount Float
  cgst        Float
  sgst        Float
  spareType   SpareType?

  createdAt DateTime @default(now())
}

model Engineer {
  id             String  @id @default(uuid())
  name           String
  email          String  @unique
  phoneNumber    String?
  specialization String?
  franchiseeId   String

  createdAt DateTime @default(now())

  assignedGoods EngineerStock[]
  orders        Order[]
}

model EngineerStock {
  id String @id @default(uuid())

  engineerId String
  engineer   Engineer @relation(fields: [engineerId], references: [id])

  materialCode String
  material     Material @relation(fields: [materialCode], references: [materialCode])

  quantity Float

  createdAt DateTime @default(now())
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id           String    @id @default(uuid())
  orderType    OrderType
  engineerId   String
  engineer     Engineer  @relation(fields: [engineerId], references: [id])
  franchiseeId String

  createdAt DateTime @default(now())

  saleOrder           SaleOrder?
  warrantyAmcOrder    WarrantyAmcOrder?
  returnToGodownOrder ReturnToGodownOrder?
}

model SaleOrder {
  id          String @id @default(uuid())
  orderId     String @unique
  order       Order  @relation(fields: [orderId], references: [id])

  billNumber    String   @unique
  dateOfSale    DateTime
  ticketNumber  String?
  customerName  String?

  materialCode  String
  material      Material  @relation(fields: [materialCode], references: [materialCode])

  description   String
  quantity      Float
  spareType     SpareType?
  price         Float

  createdAt DateTime @default(now())
}

model WarrantyAmcOrder {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  ticketNumber  String
  customerName  String
  date          DateTime

  materialCode  String
  material      Material @relation(fields: [materialCode], references: [materialCode])

  description   String
  quantity      Float
  spareType     SpareType?

  createdAt DateTime @default(now())
}

model ReturnToGodownOrder {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  referenceNumber String   @unique
  date            DateTime

  materialCode  String
  material      Material @relation(fields: [materialCode], references: [materialCode])

  description   String
  quantity      Float

  createdAt DateTime @default(now())
}

// ─── Customer Returns ─────────────────────────────────────────────────────────

model CustomerReturn {
  id           String   @id @default(uuid())
  returnDate   DateTime
  franchiseeId String

  materialCode  String
  material      Material @relation(fields: [materialCode], references: [materialCode])

  materialName  String
  quantity      Float
  pricePerUnit  Float
  totalPrice    Float

  remarks       String?

  createdAt DateTime @default(now())
}

// ─── AMC Contracts ────────────────────────────────────────────────────────────

model AmcContract {
  id           String   @id @default(uuid())
  icrNumber    String   @unique
  warrantyType String
  price        Float
  discount     Float?
  totalPrice   Float
  engineerName String
  date         DateTime
  franchiseeId String

  createdAt DateTime @default(now())
}

// ─── Godown Stock ─────────────────────────────────────────────────────────────

model GodownStock {
  id           String   @id @default(uuid())
  franchiseeId String

  materialCode String
  material     Material @relation(fields: [materialCode], references: [materialCode])

  description       String?
  hsn               String?
  uom               String?
  goodQuantity      Float      @default(0)
  defectiveQuantity Float      @default(0)
  unitPrice         Float?
  totalAmount       Float?
  cgst              Float?
  sgst              Float?
  spareType         SpareType?

  // null = manually added, set = came from an invoice
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
